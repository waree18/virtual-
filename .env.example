# ─────────────────────────────────────────────
#  Virtual Tour — Environment Configuration
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Change these for production!
SESSION_SECRET=replace_with_a_long_random_secret_string_here

# Database (relative to server.js)
DB_PATH=./database/data.sqlite

# File uploads (will be created automatically)
UPLOAD_PATH=./public/uploads

# Public URL of your site (used in reset-password emails)
BASE_URL=https://yourdomain.com

# ─────────────────────────────────────────────
#  Email (SMTP) — required for password reset
# ─────────────────────────────────────────────
# Gmail example: use App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
MAIL_FROM="Virtual Tour <your@gmail.com>"

# For SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key

# bcrypt rounds (higher = slower but more secure)
BCRYPT_ROUNDS=12
